#!/bin/bash

# 1. Kullanıcıyı tespit et (postinst ile aynı mantık)
if [ -n "$SUDO_USER" ]; then
    ASIL_KULLANICI=$SUDO_USER
elif [ -n "$PKEXEC_UID" ]; then
    ASIL_KULLANICI=$(getent passwd "$PKEXEC_UID" | cut -d: -f1)
else
    ASIL_KULLANICI=$(who | awk '{print $1}' | head -n1)
fi

EV_DIZINI=$(eval echo ~$ASIL_KULLANICI)

# 2. ~/ARK Klasörünü ve içindekileri tamamen sil
if [ -d "$EV_DIZINI/ARK" ]; then
    rm -rf "$EV_DIZINI/ARK"
fi

# 3. Başlat menüsü kısayolunu sil
if [ -f "$EV_DIZINI/.local/share/applications/ARK-okul-zili.desktop" ]; then
    rm "$EV_DIZINI/.local/share/applications/ARK-okul-zili.desktop"
fi

# 4. Uygulama simgesini sil
if [ -f "$EV_DIZINI/.local/share/icons/ark.svg" ]; then
    rm "$EV_DIZINI/.local/share/icons/ark.svg"
fi

# 5. Başlat menüsü veritabanını güncelle (Simgenin menüden anında kaybolması için)
if command -v update-desktop-database &> /dev/null; then
    sudo -u $ASIL_KULLANICI update-desktop-database "$EV_DIZINI/.local/share/applications/"
fi

exit 0